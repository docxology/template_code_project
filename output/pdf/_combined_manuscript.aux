\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Sensitivity sweep produced by \breaktt {generate\_step\_size\_sensitivity\_plot()} over an independent dense grid \(\mitalpha \in [0.005, 0.4]\) (10 points), distinct from the discrete \breaktt {experiment.step\_sizes} used elsewhere in this section. Left: iterations to convergence on log--log axes --- the curve drops sharply from 500 iterations at the smallest \(\mitalpha \) (the \texttt {max\_iterations} cap in this sub-experiment) to 37 iterations at \(\mitalpha =0.4\), illustrating the geometric speedup as \(\mitrho (\mitalpha )=|1-\mitalpha |\) shrinks. Right: final \(f(x)\) versus \(\mitalpha \) with horizontal reference lines at \(f(x_0)=0\) (initial) and \(f(x^\ast )=-0.5\) (analytic optimum); every \(\mitalpha \) in this stable window lands on the optimum.}}{9}{figure.caption.9}\protected@file@percent }
\newlabel{fig:step_sensitivity}{{4}{9}{Sensitivity sweep produced by \protect \breaktt {generate\_step\_size\_sensitivity\_plot()} over an independent dense grid \(\alpha \in [0.005, 0.4]\) (10 points), distinct from the discrete \protect \breaktt {experiment.step\_sizes} used elsewhere in this section. Left: iterations to convergence on log--log axes --- the curve drops sharply from 500 iterations at the smallest \(\alpha \) (the \protect \texttt {max\_iterations} cap in this sub-experiment) to 37 iterations at \(\alpha =0.4\), illustrating the geometric speedup as \(\rho (\alpha )=|1-\alpha |\) shrinks. Right: final \(f(x)\) versus \(\alpha \) with horizontal reference lines at \(f(x_0)=0\) (initial) and \(f(x^\ast )=-0.5\) (analytic optimum); every \(\alpha \) in this stable window lands on the optimum}{figure.caption.9}{}}
\newlabel{fig:step_sensitivity@cref}{{[figure][4][]4}{[1][8][]9}{}{}{}}
